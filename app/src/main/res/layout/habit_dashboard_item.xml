<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- habit row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- left side title and progress bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/cstmHabitTitleLabel"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- horizontal progress bar -->
            <ProgressBar
                android:id="@+id/habitProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="200dp"
                android:progressTint="#003775"
                android:indeterminateTint="#002147"
                android:layout_height="wrap_content"
                android:max="100"/>
        </LinearLayout>

        <!-- heart on the right side -->
        <ImageView
            android:id="@+id/starIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/baseline_favorite_border_24"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Star habit"/>
    </LinearLayout>

    <!-- divider line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"/>
</LinearLayout>