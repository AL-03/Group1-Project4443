<?xml version="1.0" encoding="utf-8"?>


<!-- I dont think I ever use this -->

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#CFE8FF"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/deleteBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- title -->
            <EditText
                android:id="@+id/habitTitle"
                android:hint="Habit Title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_input"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- description -->
            <EditText
                android:id="@+id/habitDesc"
                android:hint="Description"
                android:background="@drawable/rounded_input"
                android:padding="12dp"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- progress -->
            <TextView
                android:text="Progress"
                android:layout_marginTop="20dp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:max="100"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/progressInput"
                android:hint="Enter progress (0–100)"
                android:inputType="number"
                android:background="@drawable/rounded_input"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- star -->
            <ImageView
                android:id="@+id/starIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:src="@android:drawable/btn_star_big_off"
                android:clickable="true"/>

            <!-- update button -->
            <Button
                android:id="@+id/updateBtn"
                android:text="Save Changes"
                android:layout_marginTop="24dp"
                android:backgroundTint="#3A8DFF"
                android:textColor="@android:color/white"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </ScrollView>

    <!-- delete button -->
    <Button
        android:id="@+id/deleteBtn"
        android:text="Delete Habit"
        android:backgroundTint="#FF5252"
        android:textColor="@android:color/white"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>