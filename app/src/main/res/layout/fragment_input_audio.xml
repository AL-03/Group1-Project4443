<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/input_audio_frag"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CFE8FF"
    tools:context=".view.fragments.journal.InputAudioFragment">

    <!-- Button to launch system's audio recorder -->
    <ImageButton
        android:id="@+id/recordButton"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/record_button"
        android:background="@drawable/rounded_button"
        android:contentDescription="@string/record"
        android:padding="5dp"
        android:layout_margin="5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Transcription box (editable and scrollable) -->
    <ScrollView
        android:id="@+id/transcriptionBoxScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/recordButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <EditText
            android:id="@+id/transcriptionBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="120dp"
            android:maxHeight="300dp"
            android:padding="12dp"
            android:hint="@string/transcribed_text_here"
            android:background="@drawable/rounded_input"
            android:inputType="textMultiLine"
            android:overScrollMode="always"
            android:backgroundTint="#FFF"
            android:textColor="@android:color/darker_gray"
            android:textSize="14sp"
            android:gravity="top|start"
            app:layout_constraintTop_toBottomOf="@id/recordButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>