<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/input_audio_frag"
    android:layout_width="match_parent"
    android:layout_height="300dp"
    android:background="#CFE8FF"
    tools:context=".view.fragments.journal.InputDrawFragment">

    <!-- Custom drawing canvas that fills the entire fragment -->
    <com.example.eecs4443project.view.fragments.journal.DrawingView
        android:id="@+id/drawingCanvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF" />

    <!-- Floating toolbar for drawing tools -->
    <LinearLayout
        android:id="@+id/drawToolbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@drawable/draw_toolbar_bg"
        android:layout_margin="12dp"
        android:layout_gravity="top|center_horizontal">

        <!-- Undo button -->
        <ImageButton
            android:id="@+id/undoButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/undo_button"
            android:background="@android:color/transparent"
            android:contentDescription="@string/undo" />

        <!-- Redo button -->
        <ImageButton
            android:id="@+id/redoButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/redo_button"
            android:background="@android:color/transparent"
            android:contentDescription="@string/redo" />

        <!-- Pen tool -->
        <ImageButton
            android:id="@+id/penButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/draw_button"
            android:background="@android:color/transparent"
            android:contentDescription="@string/draw" />

        <!-- Eraser tool -->
        <ImageButton
            android:id="@+id/eraserButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/erase_button"
            android:background="@android:color/transparent"
            android:contentDescription="@string/clear" />
    </LinearLayout>

</FrameLayout>