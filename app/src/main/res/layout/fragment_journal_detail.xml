<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/journal_detail_frag"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CFE8FF"
    tools:context=".view.fragments.journal.JournalDetailFragment">

    <!-- Title -->
    <TextView
        android:id="@+id/journalTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:paddingTop="15dp"
        android:paddingHorizontal="15dp" />

    <!-- Divider -->
    <ImageView
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/divider"
        android:contentDescription="@string/visual_divider"
        app:layout_constraintTop_toBottomOf="@id/journalTitle"
        app:layout_constraintBottom_toTopOf="@id/modButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingTop="20dp"
        android:paddingBottom="5dp" />

    <!-- Makes both edit and delete buttons right-aligned -->
    <LinearLayout
        android:id="@+id/modButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintEnd_toEndOf="parent" >
        <!-- Edit button -->
        <ImageButton
            android:id="@+id/editButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/edit_button"
            android:backgroundTint="#FFF"
            android:contentDescription="@string/edit"
            android:padding="5dp"
            android:layout_margin="5dp" />

        <!-- Delete button -->
        <ImageButton
            android:id="@+id/delButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/delete_button"
            android:backgroundTint="#FFF"
            android:contentDescription="@string/delete"
            android:padding="5dp"
            android:layout_margin="5dp" />
    </LinearLayout>

    <!-- Entry date -->
    <TextView
        android:id="@+id/entryDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="5dp"
        android:layout_marginStart="10dp"
        android:textSize="16sp"
        android:textStyle="italic"
        app:layout_constraintTop_toBottomOf="@id/modButtons"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Entry label (if any) is right-aligned -->
    <TextView
        android:id="@+id/entryLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="5dp"
        android:layout_marginEnd="10dp"
        android:gravity="end"
        android:textSize="16sp"
        android:textStyle="italic"
        app:layout_constraintTop_toBottomOf="@id/modButtons"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Entry's main contents -->
    <ScrollView
        android:id="@+id/entryBodyScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/entryDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" >
        <TextView
            android:id="@+id/entryBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/border"
            android:layout_margin="10dp"
            android:textSize="18sp" />
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>